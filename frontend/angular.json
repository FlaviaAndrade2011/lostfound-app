{
  "$schema": "https://angular.io/generated/json/schema/angular-cli.json",
  "version": 1,
  "projects": {
    "lostfound-frontend": {
      "projectType": "application",
      "root": "src",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/favicon.ico"],
            "styles": ["src/styles.css"],
            "scripts": []
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "lostfound-frontend:build"
          }
        }
      }
    }
  },
  "defaultProject": "lostfound-frontend",
  "cli": {
    "analytics": false
  }
}
